DELIMITER $$
CREATE PROCEDURE sp_ActualizacionStock(
    IN p_cod_producto VARCHAR(50),
    IN p_cod_zona VARCHAR(50),
    IN p_cantidad_modificacion INT, -- Positivo para ENTRADA, Negativo para SALIDA
    IN p_motivo VARCHAR(100)
)
BEGIN
    DECLARE v_stock_actual INT DEFAULT 0;
    DECLARE v_stock_nuevo INT DEFAULT 0;
    DECLARE v_existe INT DEFAULT 0;
    DECLARE v_tipo_movimiento VARCHAR(20);

    -- Manejo de Errores (ROLLBACK)
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL SET MESSAGE_TEXT = 'Error al actualizar el stock. Transacción revertida.';
    END;

    START TRANSACTION;

    -- Obtener stock actual si el registro ya existe en la zona
    SELECT COUNT(*), COALESCE(stock, 0) INTO v_existe, v_stock_actual
    FROM UBICA
    WHERE Cod_producto = p_cod_producto AND cod_zona = p_cod_zona;

    -- Determinar tipo de movimiento para auditoría
    IF p_cantidad_modificacion > 0 THEN
        SET v_tipo_movimiento = 'ENTRADA';
    ELSE
        SET v_tipo_movimiento = 'SALIDA';
    END IF;

    SET v_stock_nuevo = v_stock_actual + p_cantidad_modificacion;

    -- Evitar cantidades negativas
    IF v_stock_nuevo < 0 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'La actualización resultaría en un stock negativo. Operación no permitida.';
    END IF;

    -- Modificar existencias (o crear si es una entrada nueva)
    IF v_existe > 0 THEN
        UPDATE UBICA
        SET stock = v_stock_nuevo
        WHERE Cod_producto = p_cod_producto AND cod_zona = p_cod_zona;
    ELSE
        IF v_stock_nuevo > 0 THEN
            INSERT INTO UBICA (Cod_producto, cod_zona, stock)
            VALUES (p_cod_producto, p_cod_zona, v_stock_nuevo);
        ELSE
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'No se puede crear un producto con stock cero o negativo.';
        END IF;
    END IF;

    -- Registrar fecha de actualización y movimiento en histórico (Auditoría)
    INSERT INTO HISTORICO_STOCK (
        Cod_producto, cod_zona, stock_anterior, stock_nuevo, tipo_movimiento, motivo, usuario_db
    )
    VALUES (
        p_cod_producto, p_cod_zona, v_stock_actual, v_stock_nuevo,
        v_tipo_movimiento,
        p_motivo,
        CURRENT_USER()
    );

    COMMIT;
END$$
DELIMITER ;
